{
  "name": "Geiss - Radial Zoom",
  "clearFrame": false,
  "components": [
    {
      "type": "CustomShader",
      "enabled": true,
      "code": {
        "init": "decay=0.985; scale1=0.985",
        "perFrame": "scale1=0.985 - 0.005*sin(time*0.3)"
      },
      "shader": "precision mediump float;\nuniform sampler2D tSource;\nuniform float uTime;\nuniform float uQ1;\nvarying vec2 vUv;\nvoid main() {\n  float scale1 = 0.985 + uQ1 * 0.001;\n  vec2 center = vec2(0.5);\n  vec2 uv = (vUv - center) * (1.0 / scale1) + center;\n  gl_FragColor = texture2D(tSource, uv) * 0.99;\n}"
    },
    {
      "type": "SuperScope",
      "enabled": true,
      "drawMode": "LINES",
      "audioSource": "WAVEFORM",
      "audioChannel": "CENTER",
      "colors": ["#ff6622"],
      "code": {
        "init": "n=512; t=0",
        "perFrame": "t=t+0.015; vol=getspec(0,0.1,0); base=(vol*4+0.4)-0.15; cr=base*1.07*(1+0.3*sin(t*0.73+10)); cg=base*1.07*(1+0.3*sin(t*0.54+5)); cb=base*1.07*(1+0.3*sin(t*0.91))",
        "onBeat": "",
        "perPoint": "x=(i*2-1)*0.9; y=v*0.35; red=cr; green=cg; blue=cb"
      }
    }
  ]
}
